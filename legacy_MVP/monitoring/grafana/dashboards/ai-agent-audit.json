{
  "dashboard": {
    "id": null,
    "uid": "cs6650-ai-agent",
    "title": "CS6650 - AI Agent Audit",
    "tags": ["cs6650", "ai-agent"],
    "timezone": "browser",
    "refresh": "5s",
    "time": { "from": "now-30m", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Current ECS Task Count",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "ai_agent_current_task_count",
            "legendFormat": "tasks",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "max": 8,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 4, "color": "yellow" },
                { "value": 6, "color": "orange" },
                { "value": 7, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Task Count Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "ai_agent_current_task_count",
            "legendFormat": "desired tasks",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "max": 10,
            "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "staircase": true }
          }
        }
      },
      {
        "id": 3,
        "title": "Scaling Decisions (by action)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "rate(ai_agent_decisions_total[1m])",
            "legendFormat": "{{action}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 }
          },
          "overrides": [
            { "matcher": { "id": "byName", "options": "scale_up" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "scale_down" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "no_action" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
          ]
        }
      },
      {
        "id": 4,
        "title": "Decision Latency (Claude API + Terraform)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(ai_agent_decision_latency_seconds_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(ai_agent_decision_latency_seconds_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
          }
        }
      },
      {
        "id": 5,
        "title": "Terraform Applies",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "ai_agent_terraform_applies_total",
            "legendFormat": "{{result}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "short" },
          "overrides": [
            { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
          ]
        },
        "options": { "graphMode": "area" }
      },
      {
        "id": 6,
        "title": "Total Decisions",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
        "targets": [
          {
            "expr": "sum(ai_agent_decisions_total)",
            "legendFormat": "total",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "short" }
        },
        "options": { "graphMode": "area" }
      },
      {
        "id": 7,
        "title": "Messages Consumed",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "ai_agent_messages_consumed_total",
            "legendFormat": "consumed",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "short" }
        },
        "options": { "graphMode": "area" }
      },
      {
        "id": 8,
        "title": "Cart API Request Rate (context)",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 16 },
        "targets": [
          {
            "expr": "sum(rate(cart_api_http_requests_total[30s]))",
            "legendFormat": "req/s",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
          }
        }
      }
    ]
  },
  "overwrite": true
}
