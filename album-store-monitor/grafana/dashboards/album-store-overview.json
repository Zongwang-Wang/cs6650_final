    {
      "id": 30,
      "type": "row",
      "title": "EC2 Nodes (4\u00d7 c5n.large, 25 Gbps each)",
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "CPU Utilization per Node (%)",
      "description": "c5n.large has dedicated vCPUs \u2014 no burst throttle. Sustained high CPU is real load, not credit depletion.",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 12,
        "h": 7
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "aws_ec2_cpuutilization_average",
          "legendFormat": "{{dimension_InstanceId}}"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Network Throughput (In = receiving uploads, Out = S3 + responses)",
      "description": "NetworkIn = ChaosArena uploading photos to us. NetworkOut = uploading to S3 + HTTP responses.",
      "gridPos": {
        "x": 12,
        "y": 35,
        "w": 12,
        "h": 7
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(aws_ec2_network_in_sum[1m])",
          "legendFormat": "NetworkIn ({{dimension_InstanceId}})"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(aws_ec2_network_out_sum[1m])",
          "legendFormat": "NetworkOut ({{dimension_InstanceId}})"
        }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "Application \u2014 /metrics (per-node, from Go server)",
      "description": "Scraped from each c5n.large node's /metrics endpoint. Gives per-operation Redis hit/miss breakdown, upload latency, and semaphore slot pressure.",
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Redis Hit Rate by Operation (%)",
      "description": "album_get = GET /albums/:id cache. photo_get = GET /photos/:id cache. High rate = healthy cache. Drops after Redis restart or cold start.",
      "gridPos": {
        "x": 0,
        "y": 43,
        "w": 12,
        "h": 6
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * rate(album_store_cache_hits_total{op=\"album_get\"}[1m]) / (rate(album_store_cache_hits_total{op=\"album_get\"}[1m]) + rate(album_store_cache_misses_total{op=\"album_get\"}[1m]) + 0.001)",
          "legendFormat": "Album cache hit % ({{instance}})"
        },
        {
          "datasource": "Prometheus",
          "expr": "100 * rate(album_store_cache_hits_total{op=\"photo_get\"}[1m]) / (rate(album_store_cache_hits_total{op=\"photo_get\"}[1m]) + rate(album_store_cache_misses_total{op=\"photo_get\"}[1m]) + 0.001)",
          "legendFormat": "Photo status cache hit % ({{instance}})"
        }
      ]
    },
    {
      "id": 52,
      "type": "timeseries",
      "title": "Redis Ops/s \u2014 Hits, Misses, Seq INCRs, Deletes",
      "description": "INCR = one per photo upload. Hits+Misses = cache reads. Deletes = cache invalidations on photo DELETE.",
      "gridPos": {
        "x": 12,
        "y": 43,
        "w": 12,
        "h": 6
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(album_store_cache_hits_total[1m]))",
          "legendFormat": "Cache hits/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(album_store_cache_misses_total[1m]))",
          "legendFormat": "Cache misses/s (\u2192 DB)"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(album_store_seq_incr_total[1m]))",
          "legendFormat": "Seq INCRs/s (photo uploads)"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(album_store_cache_delete_total[1m]))",
          "legendFormat": "Cache deletes/s"
        }
      ]
    },
    {
      "id": 53,
      "type": "timeseries",
      "title": "S3 Upload Duration (seconds) \u2014 processPhoto goroutine",
      "description": "Time from semaphore acquired to S3 upload complete. Separated from accept latency. High p99 = S3 bandwidth saturation or slow EC2 network.",
      "gridPos": {
        "x": 0,
        "y": 49,
        "w": 12,
        "h": 6
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(album_store_photo_upload_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(album_store_photo_upload_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(album_store_photo_upload_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 54,
      "type": "timeseries",
      "title": "Active Goroutine Semaphore Slots",
      "description": "Small (<10MB): up to 64 per node. Large (\u226510MB): up to 8 per node. Saturation = uploads queuing before S3 write.",
      "gridPos": {
        "x": 12,
        "y": 49,
        "w": 12,
        "h": 6
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Large active (max 32 total)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(album_store_active_small_uploads)",
          "legendFormat": "Small active (max 256 total)"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(album_store_active_large_uploads)",
          "legendFormat": "Large active (max 32 total)"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(album_store_photo_upload_errors_total[1m]))",
          "legendFormat": "Upload errors/s"
        }
      ]
    },
    {
      "id": 60,
      "type": "row",
      "title": "S3 \u2014 Photo Storage",
