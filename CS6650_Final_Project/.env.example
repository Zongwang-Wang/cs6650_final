# ── Album Store Endpoints ──────────────────────────────────────────────────────
# Fill these in after running `terraform apply` in final_mastery/terraform/

# ElastiCache Redis primary endpoint (no scheme, no port)
REDIS_ADDR=album-store-redis.xxxxxx.ng.0001.usw2.cache.amazonaws.com:6379

# RDS PostgreSQL (full DSN)
POSTGRES_DSN=postgresql://albumadmin:AlbumStore2024!@album-store-db.xxxx.us-west-2.rds.amazonaws.com:5432/albumstore?sslmode=require

# ALB name (used by YACE CloudWatch exporter)
ALB_NAME=album-store-alb

# S3 bucket (used by YACE)
S3_BUCKET=album-store-330214284546-us-west-2

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-west-2
# Credentials are picked up from the EC2 instance's IAM role automatically.
# No need to set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY when on EC2.

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
