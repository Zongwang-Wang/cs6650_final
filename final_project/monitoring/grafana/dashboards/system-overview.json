{
  "id": null,
  "uid": "cs6650-overview",
  "title": "CS6650 - System Overview",
  "tags": ["cs6650"],
  "timezone": "browser",
  "refresh": "5s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(cart_api_http_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "fillOpacity": 10}
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(cart_api_http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(cart_api_http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(cart_api_http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "fillOpacity": 10}
        }
      }
    },
    {
      "id": 3,
      "title": "Total Requests (counter)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(cart_api_http_requests_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "id": 4,
      "title": "Kafka Publishes",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "targets": [
        {
          "expr": "sum(cart_api_kafka_publish_total) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "id": 5,
      "title": "Kafka Publish Rate",
      "type": "timeseries",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "rate(cart_api_kafka_publish_total[1m])",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "line", "fillOpacity": 20}
        }
      }
    },
    {
      "id": 6,
      "title": "HTTP Error Rate (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum(rate(cart_api_http_requests_total{status=~\"4..|5..\"}[1m])) / sum(rate(cart_api_http_requests_total[1m])) * 100",
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 5, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "cart_api_cpu_percent",
          "legendFormat": "cart-api (realtime) {{instance}}",
          "refId": "A"
        },
        {
          "expr": "analytics_avg_cpu_percent",
          "legendFormat": "avg CPU (60s window)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 70, "color": "yellow"},
              {"value": 80, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Memory Usage (RSS)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {
          "expr": "cart_api_memory_bytes",
          "legendFormat": "container RSS {{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"drawStyle": "line", "fillOpacity": 10}
        }
      }
    },
    {
      "id": 10,
      "title": "Go Goroutines",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "go_goroutines{job=\"cart-api\"}",
          "legendFormat": "goroutines {{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "fillOpacity": 10}
        }
      }
    },
    {
      "id": 7,
      "title": "Prometheus Targets",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "DOWN", "color": "red"},
                "1": {"text": "UP", "color": "green"}
              }
            }
          ]
        }
      }
    }
  ]
}
